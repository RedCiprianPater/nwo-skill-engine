# NWO Skill Engine — Environment Variables

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nwo:nwopass@localhost:5432/nwo_skills
SYNC_DATABASE_URL=postgresql://nwo:nwopass@localhost:5432/nwo_skills

# ── Blob storage (skill payloads) ──────────────────────────────────────────────
STORAGE_BUCKET=nwo-skills
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_PUBLIC_URL=http://localhost:9000/nwo-skills
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=password123
AWS_REGION=us-east-1

# ── Embeddings ─────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
EMBEDDING_DIMENSIONS=1536

# ── Skill runtime ──────────────────────────────────────────────────────────────
RUNTIME_BACKEND=subprocess          # subprocess | docker
DOCKER_NETWORK=nwo-skills-net
SKILL_EXECUTION_TIMEOUT_SEC=120
SKILL_MAX_MEMORY_MB=512
SKILL_SANDBOX_DIR=./sandbox

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8003
API_KEY=
CORS_ORIGINS=*

# ── Marketplace ────────────────────────────────────────────────────────────────
MAX_SKILLS_PER_AGENT=500
MAX_PAYLOAD_SIZE_MB=50
ALLOW_SHELL_RUNTIME=false           # Disabled by default for security
ALLOW_DOCKER_RUNTIME=true

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
